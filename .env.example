# ============================================================
# Abouajaja_Omar/ Portfolio — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── SUPABASE BACKEND ───
# Required for database, authentication, and storage.
# Go to Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# ─── EMAIL NOTIFICATIONS (EDGE FUNCTIONS) ───
# The portfolio uses Supabase Edge Functions with Resend to 
# email you when someone submits a contact form or a client chats.
# DO NOT put these in your .env file! They must be set in Supabase:
# Run these in your terminal using the Supabase CLI:
# 
# supabase secrets set RESEND_API_KEY=re_xxxxxxxxxxxx
# supabase secrets set ADMIN_EMAIL=your@email.com
# supabase secrets set SITE_URL=https://yourdomain.com
