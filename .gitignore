# ═══════════════════════════════════════════════════
#  NEXUS ENGINE — .gitignore
# ═══════════════════════════════════════════════════

# ── Dependencies ──
node_modules/

# ── Build outputs ──
dist/
dist-ssr/
dev-dist/
.vite/

# ── Native platform builds (auto-generated by Capacitor in CI) ──
android/
ios/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment variables (NEVER commit secrets) ──
.env
.env.*
!.env.example

# ── Cache & build metadata ──
.eslintcache
*.tsbuildinfo
*.local

# ── Editor / IDE artifacts ──
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Test & media junk ──
testmedia/
coverage/

# ── Personal documents (keep out of public repo) ──
public/docs/*.pdf
